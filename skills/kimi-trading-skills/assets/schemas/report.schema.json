{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/kimi-trading-skills/report.schema.json",
  "title": "Kimi Trading Skills Report Envelope",
  "type": "object",
  "required": ["schema_version", "skill", "metadata", "data"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "skill": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": ["run_at", "data_sources"],
      "properties": {
        "run_at": {
          "type": "string",
          "format": "date-time"
        },
        "data_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "broker_adapter": {
          "type": "string"
        },
        "llm_model": {
          "type": ["string", "null"]
        }
      }
    },
    "data": {
      "type": "object"
    }
  }
}
